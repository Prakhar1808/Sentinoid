<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Sentinoid" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorOnPrimary">@color/background_dark</item>
        <item name="colorPrimaryContainer">@color/accent_green_glow</item>
        <item name="colorOnPrimaryContainer">@color/accent_green</item>
        
        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/background_dark</item>
        <item name="colorSecondaryContainer">@color/accent_blue_glow</item>
        <item name="colorOnSecondaryContainer">@color/accent_blue</item>
        
        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/accent_purple</item>
        <item name="colorOnTertiary">@color/background_dark</item>
        <item name="colorTertiaryContainer">@color/accent_purple_glow</item>
        <item name="colorOnTertiaryContainer">@color/accent_purple</item>
        
        <!-- Surface colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/background_surface</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Error colors -->
        <item name="colorError">@color/error_red</item>
        <item name="colorOnError">@color/text_primary</item>
        <item name="colorErrorContainer">@color/error_red_glow</item>
        <item name="colorOnErrorContainer">@color/error_red</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        
        <!-- Window background -->
        <item name="android:windowBackground">@color/background_dark</item>
        
        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Sentinoid.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Sentinoid.HeadlineMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Sentinoid.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Sentinoid.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Sentinoid.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Sentinoid.BodyMedium</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Sentinoid.LabelLarge</item>
    </style>
    
    <!-- Typography Styles -->
    <style name="TextAppearance.Sentinoid.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.Sentinoid.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.Sentinoid.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.Sentinoid.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.Sentinoid.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Sentinoid.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.Sentinoid.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">true</item>
    </style>
    
    <!-- Card Style -->
    <style name="Widget.Sentinoid.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.Sentinoid.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_green</item>
        <item name="android:textColor">@color/background_dark</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <style name="Widget.Sentinoid.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_blue</item>
        <item name="android:textColor">@color/accent_blue</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <style name="Widget.Sentinoid.Button.Danger" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/error_red</item>
        <item name="android:textColor">@color/error_red</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
